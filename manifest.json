{
  "manifest_version": 3,
  "name": "ScreenCapture Pro",
  "version": "1.1",
  "description": "Capture full-page screenshots and edit them with annotations, blur, crop and more.",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "downloads",
    "clipboardWrite",
    "storage",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "capture-fullpage": {
      "suggested_key": { "default": "Alt+Shift+S", "mac": "Alt+Shift+S" },
      "description": "Capture full page screenshot"
    },
    "capture-visible": {
      "suggested_key": { "default": "Alt+Shift+V", "mac": "Alt+Shift+V" },
      "description": "Capture visible area"
    },
    "capture-region": {
      "suggested_key": { "default": "Alt+Shift+R", "mac": "Alt+Shift+R" },
      "description": "Capture region"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["editor.html", "recording.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
